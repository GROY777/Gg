<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>NeoBank Ultra Pro | Финтех Хаб</title>
    <style>
        :root {
            --bg: #070912;
            --card-bg: #141929;
            --accent: #6366f1;
            --text-main: #ffffff;
            --text-dim: #71717a;
            --success: #10b981;
            --danger: #ef4444;
            --gold: #fbbf24;
            --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none; }
        body { 
            margin: 0; font-family: var(--font); 
            background: var(--bg); color: var(--text-main);
            height: 100vh; overflow: hidden;
        }

        /* УВЕДОМЛЕНИЯ */
        #notification {
            position: fixed; top: -100px; left: 20px; right: 20px;
            background: var(--accent); padding: 18px; border-radius: 16px;
            display: flex; align-items: center; gap: 12px; z-index: 2000;
            transition: 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        }

        /* МОДАЛЬНОЕ ОКНО */
        #transfer-modal {
            position: fixed; bottom: -100%; left: 0; right: 0;
            background: var(--card-bg); padding: 35px 25px;
            border-radius: 30px 30px 0 0; z-index: 1500;
            transition: 0.5s ease-out; box-shadow: 0 -15px 50px rgba(0,0,0,0.9);
        }
        input {
            width: 100%; background: #0b0f1a; border: 1px solid #27272a;
            padding: 18px; border-radius: 14px; color: white; font-size: 1rem; margin-top: 10px;
        }
        .btn-send {
            width: 100%; background: var(--accent); color: white; border: none;
            padding: 18px; border-radius: 14px; font-weight: bold; margin-top: 25px;
            font-size: 1rem; cursor: pointer; transition: 0.2s;
        }
        .btn-send:active { transform: scale(0.97); opacity: 0.8; }

        /* ГЛАВНЫЙ ЭКРАН */
        #main-app { padding: 20px; height: 100vh; overflow-y: auto; padding-bottom: 120px; scrollbar-width: none; }
        #main-app::-webkit-scrollbar { display: none; }
        
        .card-visual {
            background: linear-gradient(135deg, #4f46e5 0%, #a855f7 100%);
            padding: 30px; border-radius: 32px; position: relative;
            box-shadow: 0 25px 50px rgba(79, 70, 229, 0.3); margin-bottom: 30px;
            overflow: hidden;
        }
        .card-visual::before {
            content: ''; position: absolute; inset: 0;
            background: url('data:image/svg+xml,%3Csvg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43 0c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 37c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57 43c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM58 3c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z" fill="%23fff" fill-opacity="0.05" fill-rule="evenodd"/%3E%3C/svg%3E');
        }
        .balance-val { font-size: 2.8rem; font-weight: 800; margin: 15px 0 10px; letter-spacing: -2px; }

        /* ВАЛЮТЫ */
        .rates-box {
            background: var(--card-bg); padding: 20px; border-radius: 24px; margin-bottom: 25px;
            display: grid; grid-template-columns: 1fr 1fr; gap: 15px;
        }
        .rate-item { background: #1a1f2e; padding: 15px; border-radius: 16px; border: 1px solid #27272a; }
        .rate-head { display: flex; justify-content: space-between; color: var(--text-dim); font-size: 0.8rem; }
        .rate-val { font-size: 1.3rem; font-weight: bold; margin-top: 8px; color: var(--gold); }
        .rate-graph { height: 30px; width: 100%; margin-top: 10px; stroke: var(--gold); stroke-width: 2; fill: none; }

        /* КОПИЛКА (ЦЕЛИ) */
        .goals-box { background: var(--card-bg); padding: 20px; border-radius: 24px; margin-bottom: 25px; }
        .goal-item { margin-top: 15px; background: #1a1f2e; padding: 15px; border-radius: 16px; position: relative; }
        .goal-progress-bg { width: 100%; height: 8px; background: #27272a; border-radius: 4px; margin-top: 10px; overflow: hidden; }
        .goal-progress-bar { height: 100%; background: var(--success); width: 65%; border-radius: 4px; transition: 1s ease-out; }
        .btn-add-goal { position: absolute; right: 15px; top: 15px; background: none; border: none; color: var(--accent); font-size: 1.2rem; cursor: pointer; }

        /* ТАББАР */
        .tab-bar {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: rgba(7, 9, 18, 0.9); backdrop-filter: blur(20px);
            display: flex; justify-content: space-around; padding: 18px 10px 35px;
            border-top: 1px solid #1e293b; z-index: 1000;
        }
        .nav-icon { font-size: 1.6rem; cursor: pointer; opacity: 0.4; transition: 0.3s; position: relative; }
        .nav-icon.active { opacity: 1; transform: translateY(-8px); color: var(--accent); }
        .nav-icon.active::after {
            content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);
            width: 6px; height: 6px; background: var(--accent); border-radius: 50%;
        }

        /* Оверлей */
        #overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: none; z-index: 1400; backdrop-filter: blur(5px); }
    </style>
</head>
<body>

    <div id="notification">
        <span id="notif-icon">✅</span>
        <span id="notif-text">Готово!</span>
    </div>

    <div id="overlay" onclick="closeTransfer()"></div>

    <div id="transfer-modal">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0;">Быстрый перевод</h3>
            <span onclick="closeTransfer()" style="cursor:pointer; color:var(--text-dim);">✕</span>
        </div>
        <input type="tel" id="target-phone" placeholder="+7 999 000-00-00">
        <input type="number" id="target-amount" placeholder="Сумма (₽)">
        <button class="btn-send" onclick="execTransfer()">Отправить деньги</button>
    </div>

    <div id="main-app">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h2 style="margin:0; font-weight:800; letter-spacing:-1px;">Neo<span style="color:var(--accent)">Pro</span></h2>
            <div style="position:relative; width:45px; height:45px; background:#1e293b; border-radius:50%; display:grid; place-items:center;">
                AR
                <div style="position:absolute; top:0; right:0; width:12px; height:12px; background:var(--success); border-radius:50%; border:2px solid var(--bg);"></div>
            </div>
        </div>

        <div class="card-visual">
            <div class="balance-label" style="opacity:0.7;">Доступный лимит</div>
            <div class="balance-val" id="balanceDisplay">128 500 ₽</div>
            <div style="display:flex; justify-content:space-between; margin-top:20px; font-family:monospace; letter-spacing:2px;">
                <span>•••• 8841</span>
                <span>12/26</span>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
            <div onclick="openTransfer(); playSound();" style="text-align: center; cursor:pointer;">
                <div style="background: var(--accent); width:55px; height:55px; border-radius:18px; margin: 0 auto 8px; display: grid; place-items: center; font-size:1.3rem;">💸</div>
                <span style="font-size: 0.75rem;">Перевод</span>
            </div>
            <div style="text-align: center; opacity:0.5;">
                <div style="background: #1e293b; width:55px; height:55px; border-radius:18px; margin: 0 auto 8px; display: grid; place-items: center; font-size:1.3rem;">QR</div>
                <span style="font-size: 0.75rem;">Оплата</span>
            </div>
            <div style="text-align: center; opacity:0.5;">
                <div style="background: #1e293b; width:55px; height:55px; border-radius:18px; margin: 0 auto 8px; display: grid; place-items: center; font-size:1.3rem;">💎</div>
                <span style="font-size: 0.75rem;">Бонусы</span>
            </div>
            <div style="text-align: center; opacity:0.5;">
                <div style="background: #1e293b; width:55px; height:55px; border-radius:18px; margin: 0 auto 8px; display: grid; place-items: center; font-size:1.3rem;">➕</div>
                <span style="font-size: 0.75rem;">Открыть</span>
            </div>
        </div>

        <div class="rates-box">
            <div class="rate-item">
                <div class="rate-head"><span>USD</span> <span>₽</span></div>
                <div class="rate-val">91.45</div>
                <svg class="rate-graph" viewBox="0 0 100 30"><polyline points="0,15 10,20 20,5 30,25 40,10 50,18 60,3 70,22 80,12 90,28 100,5"/></svg>
            </div>
            <div class="rate-item">
                <div class="rate-head"><span>EUR</span> <span>₽</span></div>
                <div class="rate-val">99.10</div>
                <svg class="rate-graph" style="stroke: var(--success);" viewBox="0 0 100 30"><polyline points="0,25 15,20 30,28 45,10 60,15 75,5 90,12 100,2"/></svg>
            </div>
        </div>

        <div class="goals-box">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0;">Мои цели (Копилка)</h3>
                <span style="color: var(--accent); font-size: 1.5rem; cursor:pointer;" onclick="simulateSaving()">➕</span>
            </div>
            
            <div class="goal-item" onclick="playSound()">
                <div style="display:flex; justify-content:space-between;">
                    <span style="font-weight:600;">На новый MacBook Pro</span>
                    <span style="color:var(--text-dim); font-size:0.8rem;" id="goalProgressText">97 500 / 150 000 ₽</span>
                </div>
                <div class="goal-progress-bg">
                    <div class="goal-progress-bar" id="goalBar"></div>
                </div>
            </div>
        </div>

        <h3 style="margin-bottom: 15px;">NeoMarket Offers</h3>
        <div style="display: flex; gap: 15px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none;">
            <div style="min-width: 200px; background: #221a36; padding: 20px; border-radius: 20px; border: 1px solid #4c1d95;">
                <div style="font-size: 1.5rem;">✈️</div>
                <div style="font-weight: bold; margin-top: 10px;">Кешбэк 10% на Авиа</div>
                <div style="font-size: 0.7rem; color: var(--text-dim); margin-top:5px;">При оплате картой NeoPro</div>
            </div>
            <div style="min-width: 200px; background: #141929; padding: 20px; border-radius: 20px; border: 1px solid #27272a;">
                <div style="font-size: 1.5rem;">🍿</div>
                <div style="font-weight: bold; margin-top: 10px;">Билеты в кино за 1 ₽</div>
                <div style="font-size: 0.7rem; color: var(--text-dim); margin-top:5px;">Акция выходного дня</div>
            </div>
        </div>
    </div>

    <div class="tab-bar">
        <div class="nav-icon active" onclick="playSound()">🏠</div>
        <div class="nav-icon" onclick="playSound()">📊</div>
        <div class="nav-icon" onclick="playSound()">💳</div>
        <div class="nav-icon" onclick="playSound()">⚙️</div>
    </div>

    <script>
        let balance = 128500;
        let goalSaved = 97500;
        const goalTotal = 150000;

        // Звук (Краткий клик, base64)
        const clickSound = new Audio("data:audio/wav;base64,
